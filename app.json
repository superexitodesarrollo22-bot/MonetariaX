{
  "expo": {
    "name": "MonetariaX",
    "slug": "monetariax",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A2463"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.monetariax.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "MonetariaX usa Face ID para proteger tu información financiera.",
        "NSLocalAuthenticationUsageDescription": "MonetariaX usa biometría para proteger tu información financiera."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A2463"
      },
      "package": "com.monetariax.app",
      "versionCode": 1,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "MonetariaX necesita Face ID para proteger tus datos financieros."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "monetariax-001"
      }
    }
  }
}
